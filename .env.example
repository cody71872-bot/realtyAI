PORT=3000

# Google Sheets Configuration
GOOGLE_SERVICE_ACCOUNT_PATH=path/to/your/service-account-key.json
GOOGLE_CREDENTIALS_JSON=
GOOGLE_SHEET_ID_LEADS=your-spreadsheet-id
GOOGLE_SHEET_ID_OPENHOUSE=your-spreadsheet-id
GOOGLE_SHEET_ID_CONTENT=your-spreadsheet-id

# Email Configuration (SendGrid/SMTP)
SENDGRID_API_KEY=your-sendgrid-api-key
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com
AGENT_EMAIL=agent@yourdomain.com
AGENT_NAME=Your Name

# Admin Configuration
ADMIN_PASSWORD=your-secure-password

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key

# Stripe Configuration
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STARTER_PRICE_ID=price_...
GROWTH_PRICE_ID=price_...
PRO_PRICE_ID=price_...
DOMAIN=http://localhost:3000
